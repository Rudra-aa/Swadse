rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to read public menu data
    match /artifacts/{appId}/public/data/menu/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow authenticated users to read/write their own data
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId;
    }

    // Allow authenticated users to access cart data
    match /artifacts/{appId}/carts/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId;
    }

    // Allow authenticated users to access orders
    match /artifacts/{appId}/orders/{orderId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
