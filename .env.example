# Firebase (client — public keys only; restrict in Firebase Console)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Razorpay — PUBLIC key only in frontend (rzp_test_... or rzp_live_...)
PAYMENT_PUBLIC_KEY=

# SERVER ONLY — never expose in browser or config/env.js
PAYMENT_SECRET_KEY=

# Optional: comma-separated admin emails
ADMIN_EMAILS=admin@swadse.in

# Serverless verify endpoint (relative or absolute)
PAYMENT_VERIFY_URL=/api/verify-payment

APP_ENV=production

# Public contact (shown only to signed-in users on site)
CONTACT_EMAIL=
CONTACT_PHONE=
SITE_URL=https://swaadse.in
